rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Read-only access for crowd and queue data
    match /crowd/{document=**} {
      allow read: if true;
      allow write: if false; // Only updated by backend service account
    }
    match /queues/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
